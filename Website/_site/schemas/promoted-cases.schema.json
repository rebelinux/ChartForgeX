{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chartforgex.evotec.xyz/schemas/promoted-cases.schema.json",
  "title": "PowerForge promoted example cases",
  "description": "Source-linked rendered examples for a dedicated Evotec project site.",
  "type": "object",
  "required": ["project", "cases"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri"
    },
    "project": {
      "type": "string",
      "minLength": 1
    },
    "generatedAtSource": {
      "type": "string",
      "minLength": 1
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/case"
      }
    }
  },
  "$defs": {
    "case": {
      "type": "object",
      "required": ["id", "title", "category", "summary", "source", "build", "artifacts"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "source": {
          "type": "object",
          "required": ["path", "entry", "url"],
          "additionalProperties": false,
          "properties": {
            "path": {
              "type": "string",
              "minLength": 1
            },
            "entry": {
              "type": "string",
              "minLength": 1
            },
            "url": {
              "type": "string",
              "format": "uri"
            }
          }
        },
        "build": {
          "type": "object",
          "required": ["command", "outputPath"],
          "additionalProperties": false,
          "properties": {
            "command": {
              "type": "string",
              "minLength": 1
            },
            "outputPath": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "artifacts": {
          "type": "object",
          "required": ["svg"],
          "additionalProperties": false,
          "properties": {
            "html": {
              "type": "string",
              "pattern": "^/"
            },
            "svg": {
              "type": "string",
              "pattern": "^/"
            },
            "png": {
              "type": "string",
              "pattern": "^/"
            }
          }
        }
      }
    }
  }
}
