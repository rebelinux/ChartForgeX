          },
          {
            "title": "Topology Examples",
            "url": "/examples/",
            "sections": [],
            "items": []
          },
          {
            "title": "Documentation",
            "url": "/docs/",
            "sections": [],
            "items": []
          },
          {
            "title": "Deployment",
            "url": "/docs/deployment/",
            "sections": [],
            "items": []
          }
        ]
      },
      {
        "name": "footer-resources",
        "items": [
          {
            "title": "GitHub Repository",
            "url": "https://github.com/EvotecIT/ChartForgeX",
            "external": true,
            "sections": [],
            "items": []
          },
          {
            "title": "NuGet Package",
            "url": "https://www.nuget.org/packages/ChartForgeX",
            "external": true,
            "sections": [],
