          }
        ]
      }
    ],
    "actions": [
      {
        "title": "GitHub",
        "url": "https://github.com/EvotecIT/ChartForgeX",
        "cssClass": "nav-link",
        "ariaLabel": "ChartForgeX on GitHub",
        "external": true,
        "sections": [],
        "items": []
      },
      {
        "title": "Install",
        "text": "Install",
        "url": "https://www.nuget.org/packages/ChartForgeX",
        "cssClass": "nav-cta",
        "ariaLabel": "Install ChartForgeX",
        "external": true,
        "sections": [],
        "items": []
      }
    ],
    "regions": [],
    "surfaces": [
      {
        "name": "main",
        "path": "/",
        "primaryMenu": "main"
      },
      {
        "name": "examples",
        "path": "/examples/",
        "primaryMenu": "main"
      },
      {
        "name": "gallery",
        "path": "/gallery/",
        "primaryMenu": "main"
      },
      {
        "name": "docs",
        "path": "/docs/",
        "collection": "docs",
        "layout": "docs",
        "primaryMenu": "main",
        "sidebarMenu": "docs"
      },
      {
        "name": "notFound",
        "path": "/404/",
        "primaryMenu": "main"
      }
    ],
    "profiles": [],
    "auto": []
  },
  "features": [
    "docs",
    "search",
    "notFound"
  ]
}